{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "declaration": true,
    "target": "ES2015",
    "lib": ["es2015", "dom"],
    "module": "es2022",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "src/__tests__"]
}
