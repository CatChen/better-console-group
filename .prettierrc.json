{
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<TYPES>",
    "<THIRD_PARTY_MODULES>",
    "^[./]"
  ],
  "overrides": [
    {
      "files": "*.js.flow",
      "options": { "parser": "babel-flow" }
    }
  ],
  "plugins": ["@ianvs/prettier-plugin-sort-imports", "prettier-plugin-package"]
}
